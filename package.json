{
  "name": "nuxt-google-sheets-import",
  "version": "0.1.26",
  "description": "Schema-driven Google Sheets import module for Nuxt Content",
  "repository": "tribeweb/nuxt-google-sheets-import",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground",
    "docs"
  ],
  "scripts": {
    "docs:dev": "cd docs && nuxt dev --extends docus",
    "docs:build": "nuxt build docs --extends docus",
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxt/kit": "^4.3.1",
    "@nuxt/ui": "^4.5.1",
    "better-sqlite3": "^12.6.2",
    "js-yaml": "^4.1.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.95",
    "@nuxt/devtools": "^3.2.1",
    "@nuxt/eslint-config": "^1.15.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.3.1",
    "@nuxt/test-utils": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "latest",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.1",
    "nuxt": "^4.3.1",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
